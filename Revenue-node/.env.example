# Prisma Database URL
DATABASE_URL="postgresql://usuario:senha@host:5432/database?schema=public"

# JWT Secret (gere uma chave segura com pelo menos 32 caracteres)
JWT_SECRET=sua_chave_secreta_aqui_mude_em_producao

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000
