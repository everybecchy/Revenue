generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  instagram    String?
  role         String   @default("affiliate")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions        Session[]
  affiliateMetric AffiliateMetric?
  affiliateHouses AffiliateHouse[]
  cpaRecords      CpaRecord[]
  withdrawals     Withdrawal[]

  @@map("users")
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model BettingHouse {
  id             Int      @id @default(autoincrement())
  name           String
  cpaPercentage  Decimal  @default(0) @map("cpa_percentage") @db.Decimal(5, 2)
  affiliateLink  String?  @map("affiliate_link")
  logoUrl        String?  @map("logo_url")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  affiliateHouses AffiliateHouse[]
  cpaRecords      CpaRecord[]

  @@map("betting_houses")
}

model AffiliateMetric {
  id        Int      @id @default(autoincrement())
  userId    Int?     @unique @map("user_id")
  registros Int      @default(0)
  ftd       Int      @default(0)
  qftd      Int      @default(0)
  depositos Decimal  @default(0) @db.Decimal(12, 2)
  rev       Decimal  @default(0) @db.Decimal(12, 2)
  cpa       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("affiliate_metrics")
}

model AffiliateHouse {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  houseId      Int?     @map("house_id")
  cpaAgreement Decimal  @default(0) @map("cpa_agreement") @db.Decimal(12, 2)
  customLink   String?  @map("custom_link")
  isActive     Boolean  @default(false) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user  User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  house BettingHouse? @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([userId, houseId])
  @@map("affiliate_houses")
}

model CpaRecord {
  id           Int       @id @default(autoincrement())
  userId       Int?      @map("user_id")
  houseId      Int?      @map("house_id")
  playerName   String?   @map("player_name")
  cpaValue     Decimal   @map("cpa_value") @db.Decimal(12, 2)
  depositValue Decimal   @default(0) @map("deposit_value") @db.Decimal(12, 2)
  notes        String?
  status       String    @default("pending")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user  User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  house BettingHouse? @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@map("cpa_records")
}

model Withdrawal {
  id          Int              @id @default(autoincrement())
  userId      Int?             @map("user_id")
  amount      Decimal          @db.Decimal(12, 2)
  pixKey      String?          @map("pix_key")
  pixType     String?          @map("pix_type")
  status      String           @default("pending")
  notes       String?
  processedAt DateTime?        @map("processed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("withdrawals")
}